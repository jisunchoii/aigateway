# =============================================================================
# 1. 공통 배포값
# =============================================================================

prefix               = "aigw"
env                  = "dev"
location             = "eastus2"
owner                = "platform-team@example.com"
cost_center          = "CC-1234"
apim_publisher_name  = "Platform Team"
apim_publisher_email = "platform-team@example.com"
apim_sku_name        = "Developer_1"

# 외부 개발 도구에서 APIM에 접근하도록 공용으로 노출하려면 true로 변경합니다.
apim_public = false

# Admin UI 이미지를 배포할 때 외부 브라우저에서 열어야 하면 true로 설정합니다.
# 이 값은 전용 Admin UI 환경에만 적용되며, sidecar 환경은 항상 내부 ILB로 유지됩니다.
admin_ui_public = false
# 전용 Admin UI Container Apps 환경 subnet입니다. 다른 VNet subnet과 겹치지 않아야 합니다.
# admin_ui_aca_subnet_cidr = "10.40.5.32/27"

# =============================================================================
# 2. 모델 백엔드
# =============================================================================

# 배포 경로 1: 신규 모델 배포
# reuse_foundry=false, reuse_foundry_project=false로 두면 Terraform이 AIServices 계정,
# codexproj 프로젝트, 아래 지원 모델 배포, Private Endpoint, RBAC를 생성합니다.
reuse_foundry                         = false
reuse_foundry_project                 = false
foundry_project_name                  = "codexproj"
foundry_public_network_access_enabled = false

# 신규 모델 배포에서 Terraform이 생성할 지원 모델입니다. 배포 이름은 실제 모델 이름과 같습니다.
model_deployments = {
  "gpt-5.6-sol" = {
    model_name    = "gpt-5.6-sol"
    model_format  = "OpenAI"
    model_version = "2026-07-09"
    sku_name      = "GlobalStandard"
    capacity      = 500
  }
  "FW-GLM-5.2" = {
    model_name    = "FW-GLM-5.2"
    model_format  = "Fireworks"
    model_version = "1"
    sku_name      = "DataZoneStandard"
    capacity      = 500
  }
  "DeepSeek-V4-Pro" = {
    model_name    = "DeepSeek-V4-Pro"
    model_format  = "DeepSeek"
    model_version = "2026-04-23"
    sku_name      = "GlobalStandard"
    capacity      = 500
  }
  "grok-4.3" = {
    model_name    = "grok-4.3"
    model_format  = "xAI"
    model_version = "1"
    sku_name      = "GlobalStandard"
    capacity      = 500
  }
}

# Codex Responses 요청을 Foundry로 직접 전달할 호환성 검증 완료 deployment 목록입니다.
# 모델 이름이나 provider로 자동 판별하지 않습니다. Responses custom tool 지원을 확인한 모델만 추가하세요.
native_responses_models = ["gpt-5.6-sol"]

# 배포 경로 2: 기존 모델 활용 + 프로젝트 없음
# reuse_foundry=true, reuse_foundry_project=false로 바꾸고 기존 AIServices 계정의
# 정확한 이름과 리소스 그룹을 입력합니다.
# Terraform은 기존 모델 배포를 관리하지 않고 codexproj 프로젝트, 게이트웨이용 Private Endpoint,
# APIM 역할 할당을 생성합니다.
#
# 배포 경로 3: 기존 모델 활용 + 프로젝트 있음
# 경로 2의 값에서 reuse_foundry_project=true로 바꾸고 foundry_project_name을 실제
# 프로젝트 이름으로 입력합니다. Terraform은 기존 프로젝트를 조회만 하며 import하지 않습니다.
# 같은 목적의 Private Endpoint 또는 APIM 역할 할당이 이미 있으면 정확한 Terraform
# 리소스 주소로 import합니다. 이름만으로 일치한다고 판단하지 말고 계정 ID,
# APIM principal ID, 역할, 리소스 ID를 확인합니다.
# 두 재사용 경로 모두 위 model_deployments 키를 기존 계정의 실제 배포 이름과 일치시키고
# capacity를 해당 배포의 운영 한도에 맞춥니다. 재사용 모드에서는 모델 배포를 생성하거나
# 수정하지 않지만, 이 값은 APIM 허용 모델 목록과 모델별 TPM 계산에 사용됩니다.
existing_foundry_name = ""
existing_foundry_rg   = ""

# =============================================================================
# 3. 컨테이너 이미지 — 첫 번째 apply는 모두 빈 값
# =============================================================================

# 첫 번째 apply:
# - 아래 네 값은 모두 빈 문자열로 둡니다.
# - Terraform은 ACR을 만들지만, 아직 존재하지 않는 이미지를 참조하는
#   Container App과 Container Apps Job은 만들지 않습니다.
#
# 이미지 빌드 후 두 번째 apply:
# - 아래 기존 네 줄의 빈 문자열을 전체 이미지 URI로 교체합니다.
# - 같은 변수를 새로 추가하면 중복 정의 오류가 나므로 기존 값을 교체하세요.
# - <registry_login_server>는 `terraform output -raw registry_login_server`로 확인합니다.
# - <git-sha>는 `git rev-parse --short=12 HEAD` 결과를 사용합니다.
# - build 후 배포할 Git SHA 태그를 ACR에서 write-disabled 상태로 잠급니다.
worker_image     = ""
admin_ui_image   = ""
codexproxy_image = ""
searchmcp_image  = ""

# Admin UI를 배포할 때 아래 빈 값을 Entra 구성값으로 교체합니다.
entra_tenant_id       = ""
admin_group_object_id = ""
bff_api_audience      = ""
spa_client_id         = ""

# 두 번째 apply 교체 형식:
# worker_image     = "<registry_login_server>/config-sync-worker:<git-sha>"
# admin_ui_image   = "<registry_login_server>/admin-ui:<git-sha>"
# codexproxy_image = "<registry_login_server>/codexproxy:<git-sha>"
# searchmcp_image  = "<registry_login_server>/searchmcp:<git-sha>"

# =============================================================================
# 4. 비용 한도
# =============================================================================

monthly_budget_amount = 200
budget_alert_email    = "platform-team@example.com"

# apply하는 달의 1일 00:00 UTC를 입력합니다. 과거 달이면 Azure가 거부합니다.
budget_start_date = "2026-07-01T00:00:00Z"

# =============================================================================
# 5. 선택 기능 — jumpbox
# =============================================================================

# eastus2에서는 B-series VM 크기가 제한될 수 있으므로 D-series v7을 사용합니다.
jumpbox_vm_size = "Standard_D2s_v7"

# Bastion과 진단 VM을 만들 때는 true로 변경합니다.
# 관리자 비밀번호는 이 파일에 넣지 말고 TF_VAR_jumpbox_admin_password 환경 변수로 전달합니다.
enable_jumpbox = false
