prefix               = "aigw"
env                  = "dev"
location             = "eastus2"
owner                = "platform-team@example.com"
cost_center          = "CC-1234"
apim_publisher_name  = "Platform Team"
apim_publisher_email = "platform-team@example.com"
apim_sku_name        = "Developer_1"
# apim_public        = true   # uncomment to expose APIM publicly (external dev tools)

# ── Model backend ──────────────────────────────────────────────────────────
# Pick ONE path: greenfield (create) below, or brownfield reuse (commented).
reuse_foundry = false
foundry_project_name                  = "codexproj"
foundry_public_network_access_enabled = false

# Greenfield: Terraform creates these canonical deployments. Deployment name = real model name.
model_deployments = {
  "gpt-5.6-sol" = {
    model_name    = "gpt-5.6-sol"
    model_format  = "OpenAI"
    model_version = "2026-07-09"
    sku_name      = "GlobalStandard"
    capacity      = 500
  }
  "FW-GLM-5.2" = {
    model_name    = "FW-GLM-5.2"
    model_format  = "Fireworks"
    model_version = "1"
    sku_name      = "DataZoneStandard"
    capacity      = 500
  }
  "DeepSeek-V4-Pro" = {
    model_name    = "DeepSeek-V4-Pro"
    model_format  = "DeepSeek"
    model_version = "2026-04-23"
    sku_name      = "GlobalStandard"
    capacity      = 500
  }
  "grok-4.3" = {
    model_name    = "grok-4.3"
    model_format  = "xAI"
    model_version = "1"
    sku_name      = "GlobalStandard"
    capacity      = 500
  }
}

# External-final brownfield only: set reuse_foundry=true and point to the exact EXISTING
# account resource. Preflight/import an existing codexproj, gateway PE, and APIM roles.
# Verify account ID, APIM principal ID, role, and resource ID; never infer a match by name.
# Sidecar-era state that already owns project_account/project/project_models must instead
# keep reuse_foundry=false and set foundry_account_name to the exact state-owned account name.
# Keep this canonical model_deployments block aligned with the selected account catalog.
# existing_foundry_name = "<existing-aiservices-account>"
# existing_foundry_rg   = "<existing-resource-group>"

# /openai/v1/responses sidecar bootstrap
# First apply: leave empty so Terraform can create ACR and the rest of the gateway.
codexproxy_image = ""

# Second apply after an immutable ACR build:
# codexproxy_image = "acraigwabc123.azurecr.io/codexproxy:<git-sha>"

# Bounded Search MCP bootstrap. Leave empty on the first apply.
searchmcp_image = ""

# Second apply after an immutable ACR build:
# searchmcp_image = "acraigwabc123.azurecr.io/searchmcp:<git-sha>"

# Cost guardrail (observability module)
monthly_budget_amount = 200
budget_alert_email    = "platform-team@example.com"
budget_start_date     = "2026-07-01T00:00:00Z"  # 반드시 apply 당월 1일(UTC). 과거 달이면 Azure가 거부

# eastus2 may restrict B-series VM sizes; use a D-series v7 for the optional jumpbox.
jumpbox_vm_size = "Standard_D2s_v7"

# App config — uncomment both to provision the optional jumpbox (Bastion + VM)
# enable_jumpbox         = true
# jumpbox_admin_password = "<PASSWORD>"
