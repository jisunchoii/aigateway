prefix               = "aigw"
env                  = "dev"
location             = "eastus2"
owner                = "platform-team@example.com"
cost_center          = "CC-1234"
apim_publisher_name  = "Platform Team"
apim_publisher_email = "platform-team@example.com"
apim_sku_name        = "Developer_1"

# Cost guardrail (observability module)
monthly_budget_amount = 200
budget_alert_email    = "platform-team@example.com"
budget_start_date     = "2026-06-01T00:00:00Z"

# eastus2 may restrict B-series VM sizes; use a D-series v7 for the optional jumpbox.
jumpbox_vm_size = "Standard_D2s_v7"

# App config
# enable_jumpbox         = true <- uncomment if you want to provision a jumpbox
# jumpbox_admin_password = "<PASSWORD>" <- <- uncomment and fill in if you want to provision a jumpbox